{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/ai/**",
              "components/core/**",
              "components/data-display/**",
              "ui_kits/pmmetricsai/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnomalyCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|metric|title|confidence|why|action|actual|target|sources|regulatory|style|key|ref|className|style|children)$/]",
        "message": "<AnomalyCard> doesn't accept that prop. Declared props: level, metric, title, confidence, why, action, actual, target, sources, regulatory, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnomalyCard'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:RED|AMBER|INFO)$/]",
        "message": "<AnomalyCard> level must be one of 'RED' | 'AMBER' | 'INFO'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|leadingIcon|trailingIcon|onClick|type|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, leadingIcon, trailingIcon, onClick, type, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|target|variance|trend|status|icon|style|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: label, value, target, variance, trend, status, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='trend'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<MetricCard> trend must be one of 'up' | 'down' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:good|watch|escalate|neutral)$/]",
        "message": "<MetricCard> status must be one of 'good' | 'watch' | 'escalate' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|dot|children|style|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: status, dot, children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
